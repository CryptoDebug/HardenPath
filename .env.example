# Used by Prisma when you run the app locally with npm.
DATABASE_URL="postgresql://hardenpath:hardenpath_dev_password@localhost:5432/hardenpath?schema=public"

# Used by Docker Compose for the PostgreSQL container.
POSTGRES_DB="hardenpath"
POSTGRES_USER="hardenpath"
POSTGRES_PASSWORD="hardenpath_dev_password"

# Used by NextAuth.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-a-random-secret"
